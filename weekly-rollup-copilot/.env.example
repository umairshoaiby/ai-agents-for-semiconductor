# Copy this file to .env and fill in your key.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (defaults to claude-opus-4-8).
# Cheaper/faster options: claude-sonnet-4-6, claude-haiku-4-5
# ROLLUP_MODEL=claude-sonnet-4-6

# Optional: anchor "today" for age/slip math (defaults to the sample week).
# ROLLUP_TODAY=2026-06-14

# Optional: retune program thresholds without touching code.
# ROLLUP_STALE_DAYS=7
# ROLLUP_SLIP_DAYS=10
# ROLLUP_HOT_TOPIC_MIN_MENTIONS=2
