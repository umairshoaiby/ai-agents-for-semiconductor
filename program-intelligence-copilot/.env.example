# Copy to .env and fill in keys as needed.

# For the AI answer/agents (ask.py, later phases). Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Embeddings provider: "local" (lexical BM25, no key, runs anywhere — default) or
# "voyage" (semantic hybrid retrieval; needs the key below).
EMBED_PROVIDER=local
# VOYAGE_API_KEY=pa-...           # required only when EMBED_PROVIDER=voyage
# EMBED_MODEL=voyage-3            # default

# Optional model overrides
# PIC_MODEL=claude-opus-4-8       # synthesis / answering
# PIC_SUBAGENT_MODEL=claude-haiku-4-5
